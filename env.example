# ── Shopify App Credentials ──────────────────────────────────────
# Get these from your Shopify Partner Dashboard > Apps > Your App > API credentials
SHOPIFY_API_KEY=your_shopify_api_key_here
SHOPIFY_API_SECRET=your_shopify_api_secret_here

# ── App Host ─────────────────────────────────────────────────────
# Your Netlify site URL (no trailing slash). Update after first deploy.
# Example: https://rothley-price-lock.netlify.app
HOST=https://your-netlify-site.netlify.app

# ── Shopify Store ─────────────────────────────────────────────────
# The .myshopify.com domain of your store
SHOP=rothley.myshopify.com

# ── Session Secret ────────────────────────────────────────────────
# A random 32+ character string for signing session tokens
SESSION_SECRET=replace_with_a_long_random_string_at_least_32_chars

# ── Shopify API Version ───────────────────────────────────────────
SHOPIFY_API_VERSION=2025-01

# ── Database ─────────────────────────────────────────────────────
# Path to the SQLite database file (relative to function root)
# Netlify wraps /tmp for writable storage at runtime
DB_PATH=/tmp/rothley-price-lock.db
